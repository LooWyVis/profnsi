% --- doc
% name: \lignes
% kind: newcommand
% args:
%   num: 1
% description: Commande : \lignes{<nombre>}, fais des lignes pour ecrire
% example: \lignes{4}
% meta:
%   file: profnsi.sty
% --- end-doc
\newcommand{\lignes}[1]{%
	\par\vspace{0.5em}%
	\noindent
	\foreach \i in {1,...,#1}{%
		\noindent\makebox[\linewidth]{\dotfill}\par\vspace{0.8em}%
	}%
}

% Définition de la boîte Application
% (identique, sauf qu'on autorise des options facultatives via [1][] pour le titre custom)
\newtcolorbox{applicationbox}[1][]{%
	colback=white,                      % fond intérieur
	colframe=gray!70,                   % bordure gris clair
	coltitle=black,                     % couleur du titre
	colbacktitle=gray!20,               % fond de l'en-tête gris clair
	title=\textbf{Application},         % texte de l'en-tête (défaut)
	fonttitle=\large,                   % taille du titre
	enhanced,                           % activer options avancées
	arc=10pt,                           % coins bien arrondis
	boxrule=0.6pt,                      % épaisseur de la bordure
	borderline={0.5pt}{0pt},   % ligne pointillée intérieure
	top=6pt, bottom=6pt, left=8pt, right=8pt, % marges internes
	#1                                  % <-- permet de surcharger (ex: title=...)
}

% --- doc
% name: \application
% kind: NewDocumentCommand
% args:
%   spec: o m g
% description: Commande \application Creer une boite d'application
% example: \application{Contenu}{<nb lignes>} - \application[Titre perso]{Contenu}{<nb lignes>}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\application}{o m g}{%
	\IfNoValueTF{#1}{%
		\begin{applicationbox}%
			#2%
			\IfNoValueF{#3}{\par\lignes{#3}}%
		\end{applicationbox}%
	}{%
		\begin{applicationbox}[title=\textbf{#1}]%
			#2%
			\IfNoValueF{#3}{\par\lignes{#3}}%
		\end{applicationbox}%
	}%
}

% Style de base (noir & blanc, fond gris très léger)
\lstdefinestyle{codebase}{
	basicstyle=\small,
	numbers=left,
	numbersep=6pt,
	frame=single,
	framerule=0.4pt,
	backgroundcolor=\color{gray!5},
	showstringspaces=false,
	columns=fullflexible,
	keepspaces=true,
	breaklines=true,
	breakatwhitespace=true,
	upquote=true,
	tabsize=2,
	keywordstyle=\color{black}\bfseries
}

% Langages (JS peut ne pas être pré-défini selon distributions : on le déclare au besoin)
\lstdefinelanguage{JavaScript}{
	morekeywords={break,case,catch,class,const,continue,debugger,default,delete,do,else,export,extends,
		finally,for,function,if,import,in,instanceof,let,new,return,super,switch,this,throw,try,typeof,var,void,while,yield},
	sensitive=true,
	morecomment=[l]{//},
	morecomment=[s]{/*}{*/},
	morestring=[b]', morestring=[b]"
}

% Environnements blocs — argument optionnel [<options listings>] pour ajuster au besoin
\lstnewenvironment{python}[1][] {
	\lstset{
		style=codebase,
		frameround=tttn,
		language=Python
	}
}{}
\lstnewenvironment{sql} [1][] {
	\lstset{
		language=SQL,
		style=codebase,
		showstringspaces=false,
		morekeywords={*},
	}
}{}
\lstnewenvironment{html}[1][] {
	\lstset{
		style=codebase,
		frameround=tttn,
		language=HTML
	}
}{}
\lstnewenvironment{css}[1][] {
	\lstset{
		style=codebase,
		frameround=tttn,
		language=CSS
	}
}{}
\lstnewenvironment{js}[1][] {
	\lstset{
		style=codebase,
		frameround=tttn,
		language=JavaScript
	}
}{}
\lstnewenvironment{bash}[1][]{
	\lstset{
		style=codebase,
		frameround=tttn,
		language=bash,
		numbers=none,
		morekeywords={ls, sudo, mkdir}
	}
}{}

