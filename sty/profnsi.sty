% --- doc
% name: \tableau
% kind: newcommand
% args:
%   num: 2
% description: Affiche un tableau
% example: \tableau{Décimal|Binaire}{4|100 ; 5|101 ; 6|110}, \tableau[.5\linewidth]{Tour|i|compteur}{0|0|0 ;1|1|1 ;10|2|2}
% meta:
%   file: profnsi.sty
% --- end-doc
\newcolumntype{Y}{>{\centering\arraybackslash}X}

\makeatletter
\NewDocumentCommand{\tableau}{ O{\linewidth} m m }{%
	% nb de colonnes = nb de | + 1
	\StrCount{#2}{|}[\tbl@bars]%
	\edef\tbl@cols{\the\numexpr\tbl@bars+1\relax}%
	% préparer en-têtes / corps
	\StrSubstitute{#2}{|}{&}[\tbl@head]%
	\StrSubstitute{#3}{;}{\\}[\tbl@bodyA]%
	\StrSubstitute{\tbl@bodyA}{|}{&}[\tbl@body]%
	%
	\begin{center}
		\small
		\begin{tabularx}{#1}{|*{\tbl@cols}{Y|}}
			\hline
			\tbl@head\\ \hline
			\tbl@body\\ \hline
		\end{tabularx}
	\end{center}
}
\makeatother

% --- doc
% name: \arbre
% kind: newcommand
% args:
%   num: 1
% description: Affiche un arbre
% example: \arbre{[A [B] [C [E] [F]] [D]]}, \arbre{[/ [bin] [users [louis] [jean]] [dev] ]}
% meta:
%   file: profnsi.sty
% --- end-doc
\forestset{
	arbre/.style={
		for tree={
			draw,
			rounded corners,
			align=center,
			inner sep=2pt,
			outer sep=0pt,
			s sep=4mm,            % espace horizontal entre frères/soeurs
			l sep=9mm,            % espace vertical entre niveaux
			edge={-Latex},        % jolis traits avec flèche
			font=\small,
		},
		% Clés utilisateur (fr)
		niveau sep/.style   ={l sep=#1},
		fratrie sep/.style  ={s sep=#1},
		dir/.style          ={grow'=#1},      % up, down, left, right
		rect/.style         ={for tree/.append style={rounded corners=0}},
		sanscadre/.style    ={for tree/.append style={draw=none}},
		rempli/.style       ={for tree/.append style={fill=#1}},
		texte/.style        ={for tree/.append style={font=#1}},
		largeur/.style      ={for tree/.append style={text width=#1}},
		centrer/.style      ={for tree/.append style={align=center}},
		gauche/.style       ={for tree/.append style={align=left}},
		droite/.style       ={for tree/.append style={align=right}},
	},
}

\NewDocumentCommand{\arbre}{O{} m}{%
