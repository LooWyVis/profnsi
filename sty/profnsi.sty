% --------- En-tête type ÉVALUATION (DS) ----------
\newcommand{\profnsi@EvalHeader}{%
  \@ifclassloaded{exam}{%
    \pagestyle{headandfoot}%
    \firstpageheadrule
    \firstpageheader{\profnsi@matiere}{\textbf{Évaluation : \ifx\profnsi@titre\@empty Titre\else \profnsi@titre\fi}}{\profnsi@niveau}%
    \ifprofversion
      \vspace{1em}\noindent\textbf{Corrigé — Version Prof}\par\vspace{0.5em}%
    \else
      \noindent\textbf{Nom :} \rule{0.35\linewidth}{0.4pt}\\
      \textbf{Prénom :} \rule{0.35\linewidth}{0.4pt}\\
      \textbf{Classe :} \rule{0.1\linewidth}{0.4pt}\par
      \vspace{0.5em}%
    \fi
    \doublebar
  }{%
    \pagestyle{plain}%
    {\large \textbf{\profnsi@matiere}}\par
    \vspace{0.6em}
    \begin{center}
      \Large \textbf{Évaluation : }\textbf{\ifx\profnsi@titre\@empty Titre\else \profnsi@titre\fi}
    \end{center}
    \vspace{0.6em}
    \ifprofversion
      \noindent\textbf{Corrigé — Version Prof}\par
    \else
      \noindent\textbf{Nom :} \rule{0.35\linewidth}{0.4pt}\hfill
      \textbf{Prénom :} \rule{0.35\linewidth}{0.4pt}\par
      \vspace{0.5em}%
    \fi
    \doublebar
  }%
}

% --------- En-tête type COURS / EXERCICES / TP ----------
\newcommand{\profnsi@PedagoHeader}{%
  \pagestyle{plain}%
  {\normalsize
    \ifx\profnsi@chapitre\@empty\else
      \noindent Chapitre \profnsi@chapitre
    \fi
    \hfill
    \ifx\profnsi@niveau\@empty\else
      \profnsi@niveau~\profnsi@matiere
    \fi
  }\par
  \vspace{0.8em}
  \begin{center}
    {\Large \textbf{\ifx\profnsi@titre\@empty Titre du document\else \profnsi@titre\fi}}\par
    \vspace{0.8em}
    {\normalsize \textbf{\MakeUppercase{\@typeDocument}}%
      \ifprofversion~—~Version Prof\fi}
  \end{center}
  \doublebar
}

% --------- En-tête type PROJET ----------
\newcommand{\profnsi@ProjetHeader}{%
  \pagestyle{plain}%
  \begin{center}
    {\Large \textbf{\ifx\profnsi@titre\@empty Titre du document\else \profnsi@titre\fi}}\par
    \vspace{0.8em}
    {\normalsize \textbf{\MakeUppercase{\@typeDocument}}}
  \end{center}
  \doublebar
}

% --------- En-tête type Interro ----------
\newcommand{\profnsi@InterroHeader}{%
	\pagestyle{empty}%
	\noindent
	Nom, Prénom : \dotfill
	\hfill
	\ifx\profnsi@niveau\@empty\else \profnsi@niveau\fi
	\ifx\profnsi@matiere\@empty\else\ \profnsi@matiere\fi
	\par
	\vspace{1em}
	\begin{center}
		\fbox{%
			\parbox{\textwidth}{%
				\centering \textbf{\ifx\profnsi@titre\@empty Interrogation\else \profnsi@titre\fi}%
			}%
		}
	\end{center}
	\vspace{1em}
}

% --- doc
% name: \creerDoc
% kind: newcommand
% args: {}
% description: Creer le template du document
% example: \creerDoc
% meta:
%   file: profnsi.sty
% --- end-doc
\newcommand{\creerDoc}{%
	\par\noindent
	\ifthenelse{\equal{\@typeDocument}{ds}}{%
		\profnsi@EvalHeader
	}{%
		\ifthenelse{\equal{\@typeDocument}{projet}}{%
			\profnsi@ProjetHeader
		}{%
			\ifthenelse{\equal{\@typeDocument}{interro}}{%
				\profnsi@InterroHeader
			}{%
				\profnsi@PedagoHeader
			}%
		}%
	}%
	\vspace{0.5em}%
}

\makeatother

% ============================================================
% Compteurs
% ============================================================

\newcounter{compteurpartie}
\newcounter{compteursouspartie}
\newcounter{compteurexercice}

% ============================================================
% Cours : parties et sous-parties
% ============================================================

\renewcommand{\thecompteurpartie}{\arabic{compteurpartie}}
\renewcommand{\thecompteursouspartie}{\thecompteurpartie.\arabic{compteursouspartie}}

\newcommand{\prefixepartie}{Partie}

\newif\ifpartiesDansSommaire
\partiesDansSommairefalse

% --- doc
% name: \activerSommaireParties
% kind: NewDocumentCommand
% args:
%   spec: s
% description: Afficher le sommaire dans le document :\n- non étoilée : active + imprime le sommaire + saute de page\n- étoilée : active seulement (pas d'impression)
% example: \activerSommaireParties
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\activerSommaireParties}{s}{%
  \partiesDansSommairetrue
  \IfBooleanF{#1}{%
    \tableofcontents
    \newpage
  }%
}

% --- doc
% name: \partie
% kind: NewDocumentCommand
% args:
%   spec: s o m
% description: Début d'une partie
% example: \partie{Le système binaire}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\partie}{s o m}{%
  \IfBooleanTF{#1}{%
    \section*{\prefixepartie\ \ #3}%
  }{%
    \refstepcounter{compteurpartie}%
    \setcounter{compteursouspartie}{0}%
    \section*{\prefixepartie\ \thecompteurpartie\ :\ \ #3}%
    \ifpartiesDansSommaire
      \addcontentsline{toc}{section}{%
        \IfNoValueTF{#2}{\prefixepartie\ \thecompteurpartie\ :\ #3}{#2}%
      }%
    \fi
  }%
  \setcounter{compteurexercice}{0}%
}

% --- doc
% name: \souspartie
% kind: NewDocumentCommand
% args:
%   spec: s o m
% description: Sous partie
% example: \souspartie{Conversions}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\souspartie}{s o m}{%
  \IfBooleanTF{#1}{%
    \section*{#3}%
  }{%
    \refstepcounter{compteursouspartie}%
    \section*{\thecompteursouspartie\ \hrulefill\ \ #3}%
    \ifpartiesDansSommaire
      \addcontentsline{toc}{subsection}{%
        \IfNoValueTF{#2}{\thecompteursouspartie\ \ #3}{#2}%
      }%
    \fi
  }%
}

