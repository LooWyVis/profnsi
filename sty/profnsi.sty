% --- doc
% name: \pile
% kind: NewDocumentCommand
% args:
%   spec: m
% description: Représenter une pile
% example: \pile{[2, 4, 3, 9, 5]}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\pile}{m}{%
	% 1. Retirer les crochets et remplacer les virgules par des fins de ligne
	\StrGobbleLeft{#1}{1}[\tempA]
	\StrGobbleRight{\tempA}{1}[\tempB]
	\StrSubstitute{\tempB}{,}{ \\ }[\tempC]
	
	% 2. Encapsuler la structure de la pile dans un noeud TikZ
	\tikz[baseline=(pile.base), yshift=0.5ex] {
		% Dessiner le tableau (la Pile) et le nommer 'pile'
		\node (pile) [inner sep=0pt] {
			\begin{tabular}{|c|}
				\hline
				\tempC \\ 
				\hline
			\end{tabular}
		};
		
		% Coordonnée centrale supérieure de la pile
		\coordinate (topcenter) at (pile.north);
		
		% Flèche d'ENTRÉE (Push / Empiler) centrée, pointant vers le BAS (dans la pile)
		\draw[->, very thick] ($(topcenter) + (-0.35cm, 0.7cm)$) -- ($(topcenter) + (-0.35cm, 0.2cm)$)
		node[left] {\tiny Entrée}; % Texte "Entrée" au-dessus de la flèche
		
		% Flèche de SORTIE (Pop / Dépiler) centrée, pointant vers le HAUT (hors de la pile)
		\draw[->, very thick] ($(topcenter) + (0.35cm, 0.2cm)$) -- ($(topcenter) + (0.35cm, 0.7cm)$)
		node[right] {\tiny Sortie}; % Texte "Sortie" au-dessus de la flèche
		
	}
}

% --- doc
% name: \file
% kind: NewDocumentCommand
% args:
%   spec: m
% description: Représenter une file
% example: \file{[A, V, P, Z, H]}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\file}{m}{%
	% 1. Retirer les crochets et remplacer les virgules par des séparateurs de colonnes '&'
	\StrGobbleLeft{#1}{1}[\tempA]
	\StrGobbleRight{\tempA}{1}[\tempB]
	\StrSubstitute{\tempB}{,}{ & }[\tempC]
	
	% 2. Encapsuler la structure de la file dans un noeud TikZ
	\tikz[baseline=(file.base)] {
		% Dessiner le tableau (la File) et le nommer 'file'
		\node (file) [inner sep=0pt] {
			\begin{tabular}{|*{100}{c|}}
				\hline
				\tempC \\
				\hline
			\end{tabular}
		};
		
		% Flèche d'ENTRÉE (Enfiler / Enqueue) à droite
		\draw[->, very thick] ($(file.west) + (-0.5cm, 0)$) -- (file.west)
		node[left, midway, xshift=-0.25cm] {\tiny Entrée};
		
		% Flèche de SORTIE (Défiler / Dequeue) à gauche
		\draw[->, very thick] (file.east) -- ($(file.east) + (0.5cm, 0)$)
		node[right, midway, xshift=0.25cm] {\tiny Sortie};
	}
}

% --- doc
% name: \listechainee
% kind: newcommand
% args:
%   num: 1
% description: Représenter une liste chainée
% example: \listechainee{2, 4, 3, 9}
% meta:
%   file: profnsi.sty
% --- end-doc
\newcommand{\listechainee}[1]{%
	\begin{tikzpicture}[
		list/.style={
			rectangle split,
			rectangle split parts=2,
			rectangle split horizontal,
			draw,
			minimum height=0.5cm,
			text centered
		},
		start chain=going right,
		node distance=1cm
		]
		
		% Création des blocs pour chaque valeur
		\def\lastindex{0}%
		\foreach[count=\i] \val in {#1} {%
			\node[list,on chain] (node\i) {\val};
			\xdef\lastindex{\i}%
		}%
		
		% Bloc de fin (NULL)
		\node[on chain, draw, inner sep=6pt] (null) {};
		\draw (null.north east) -- (null.south west);
		\draw (null.north west) -- (null.south east);
		
		% Flèches entre les blocs
		\pgfmathtruncatemacro{\NminusOne}{\lastindex-1}
		\ifnum\lastindex>1
		\foreach \i in {1,...,\NminusOne} {%
			\pgfmathtruncatemacro{\j}{\i+1}
			% flèche depuis la partie "next" (split part 2) vers le bloc suivant
			\draw[-{Stealth}] 
			let \p1 = (node\i.two), \p2 = (node\i.center)
			in (\x1,\y2) -- (node\j);
		}%
		\fi
		
		% Flèche du dernier bloc vers NULL
		\ifnum\lastindex>0
		\draw[-{Stealth}]
		let \p1 = (node\lastindex.two), \p2 = (node\lastindex.center)
		in (\x1,\y2) -- (null);
		\fi
		
	\end{tikzpicture}%
}

\renewcommand{\thecompteurexercice}{Exercice \arabic{compteurexercice}}

% --- doc
% name: \exercice
% kind: NewDocumentCommand
% args:
%   spec: s o m
% description: Creer un exo
% example: 	\exercice{Binaire vers hexadécimal}, 	\exercice*{Exo non numéroté}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\exercice}{s o m}{%
	\IfBooleanTF{#1}{%
		\textbf{Exercice.} #3
	}{%
		\refstepcounter{compteurexercice}%
		\setcounter{qcmq}{0} 
		\vspace{0.2cm}
		\textbf{\thecompteurexercice.} #3
		\vspace{0.1cm}
		\noindent
	}%
}


