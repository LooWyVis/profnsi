% --- doc
% name: \lignes
% kind: newcommand
% args:
%   num: 1
% description: Commande : \lignes{<nombre>}, fais des lignes pour ecrire
% example: \lignes{4}
% meta:
%   file: profnsi.sty
% --- end-doc
\newcommand{\lignes}[1]{%
  \par\vspace{0.5em}%
  \noindent
  \foreach \i in {1,...,#1}{%
    \noindent\makebox[\linewidth]{\dotfill}\par\vspace{0.8em}%
  }%
}

% ============================================================
% Boîte : Application
% ============================================================

\newtcolorbox{applicationbox}[1][]{%
  colback=white,
  colframe=gray!70,
  coltitle=black,
  colbacktitle=gray!20,
  title=\textbf{Application},
  fonttitle=\large,
  enhanced,
  arc=10pt,
  boxrule=0.6pt,
  borderline={0.5pt}{0pt},
  top=6pt,
  bottom=6pt,
  left=8pt,
  right=8pt,
  #1
}

% --- doc
% name: \application
% kind: NewDocumentCommand
% args:
%   spec: o m g
% description: Commande \application Creer une boite d'application
% example: \application{Contenu}{<nb lignes>} - \application[Titre perso]{Contenu}{<nb lignes>}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\application}{o m g}{%
  \IfNoValueTF{#1}{%
    \begin{applicationbox}%
      #2%
      \IfNoValueF{#3}{\par\lignes{#3}}%
    \end{applicationbox}%
  }{%
    \begin{applicationbox}[title=\textbf{#1}]%
      #2%
      \IfNoValueF{#3}{\par\lignes{#3}}%
    \end{applicationbox}%
  }%
}

