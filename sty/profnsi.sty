\makeatletter
% --- doc
% name: \creerDoc
% kind: newcommand
% args: {}
% description: Creer le template du document
% example: \creerDoc
% meta:
%   file: profnsi.sty
% --- end-doc
\newcommand{\creerDoc}{%
	\par\noindent
	\ifthenelse{\equal{\@typeDocument}{ds}}{%
		\profnsi@EvalHeader
	}{%
		\ifthenelse{\equal{\@typeDocument}{projet}}{%
			\profnsi@ProjetHeader
