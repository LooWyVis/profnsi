\newcommand*\profnsi@TypeUpper{\expandafter\MakeUppercase\expandafter{\@typeDocument}}
\newcommand*\profnsi@VersionUpper{\expandafter\MakeUppercase\expandafter{\@versionDocument}}

% --------- En-tête type ÉVALUATION (DS) ----------
\newcommand{\profnsi@EvalHeader}{%
	\@ifclassloaded{exam}{%
		\pagestyle{headandfoot}%
		\firstpageheadrule
		% On enlève la "classe" comme demandé, on garde matière + titre
		\firstpageheader{\profnsi@matiere}{\textbf{Évaluation : \ifx\profnsi@titre\@empty Titre\else \profnsi@titre\fi}}{\profnsi@niveau}%
		\ifprofversion
		\vspace{1em}\noindent\textbf{Corrigé — Version Prof}\par\vspace{0.5em}%
		\else
		\noindent\textbf{Nom :} \rule{0.35\linewidth}{0.4pt}\\
		\textbf{Prénom :} \rule{0.35\linewidth}{0.4pt}\\
		\textbf{Classe :} \rule{0.1\linewidth}{0.4pt}\par
		\vspace{0.5em}%
		\fi
		\doublebar
	}{%
		% Fallback si 'exam' non chargé
		\pagestyle{plain}%
		{\large \textbf{\profnsi@matiere}}\par
		\vspace{0.6em}
		\begin{center}
			\Large \textbf{Évaluation : }\textbf{\ifx\profnsi@titre\@empty Titre\else \profnsi@titre\fi}
		\end{center}
		\vspace{0.6em}
		\ifprofversion
		\noindent\textbf{Corrigé — Version Prof}\par
		\else
		\noindent\textbf{Nom :} \rule{0.35\linewidth}{0.4pt}\hfill
		\textbf{Prénom :} \rule{0.35\linewidth}{0.4pt}\par
		\vspace{0.5em}%
		\fi
		\doublebar
	}%
}

% --------- En-tête type COURS / EXERCICES / TP ----------
\newcommand{\profnsi@PedagoHeader}{%
	\pagestyle{plain}%
	{\normalsize
		\ifx\profnsi@chapitre\@empty\else
		\noindent Chapitre \profnsi@chapitre
		\fi
		\hfill
		\ifx\profnsi@niveau\@empty\else
		\profnsi@niveau~\profnsi@matiere
		\fi
	}\par
	\vspace{0.8em}
	\begin{center}
		{\Large \textbf{\ifx\profnsi@titre\@empty Titre du document\else \profnsi@titre\fi}}\par
		\vspace{0.8em}
		{\normalsize \textbf{\MakeUppercase{\@typeDocument}}%
			\ifprofversion~—~Version Prof\fi}
	\end{center}
	\doublebar
}

% --------- En-tête type Projet ----------
\newcommand{\profnsi@ProjetHeader}{%
	\pagestyle{plain}%
	\begin{center}
		{\Large \textbf{\ifx\profnsi@titre\@empty Titre du document\else \profnsi@titre\fi}}\par
		\vspace{0.8em}
		{\normalsize \textbf{\MakeUppercase{\@typeDocument}}}
	\end{center}
	\doublebar
}

