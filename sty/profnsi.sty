% --- doc
% name: \remarque
% kind: NewDocumentCommand
% args:
%   spec: o m
% description: Creer une boite de remarque
% example: \remarque{Contenu}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\remarque}{o m}{%
  \IfNoValueTF{#1}{%
    \begin{remarquebox}{Remarque}#2\end{remarquebox}%
  }{%
    \begin{remarquebox}{#1}#2\end{remarquebox}%
  }%
