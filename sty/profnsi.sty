% ----- Config utilisateur : \profnsisetup{cle=valeur,...} -----
\def\profnsi@matiere{}
\def\profnsi@titre{}
\def\profnsi@chapitre{}
\def\profnsi@niveau{}

\makeatletter
\define@key{profnsi}{matiere}{\def\profnsi@matiere{#1}}
\define@key{profnsi}{titre}{\def\profnsi@titre{#1}}
