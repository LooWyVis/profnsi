}
\makeatother

% Compteurs
\newcounter{compteurpartie}
\newcounter{compteursouspartie}
\newcounter{compteurexercice}

% --------- Cours ----------

% ============================
% Parties & sous-parties
% ============================
\renewcommand{\thecompteurpartie}{\arabic{compteurpartie}}
\renewcommand{\thecompteursouspartie}{\thecompteurpartie.\arabic{compteursouspartie}}

\newcommand{\prefixepartie}{Partie}

% Flag global (si pas déjà défini)
\newif\ifpartiesDansSommaire
\partiesDansSommairefalse

% --- doc
% name: \activerSommaireParties
% kind: NewDocumentCommand
% args:
%   spec: s
% description: Afficher le sommaire dans le document :\n- non étoilée : active + imprime le sommaire + saute de page\n- étoilée     : active seulement (pas d'impression)
% example: \activerSommaireParties
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\activerSommaireParties}{s}{%
	\partiesDansSommairetrue
	\IfBooleanF{#1}{%
		\tableofcontents
		\newpage
	}%
}

% --- doc
% name: \partie
% kind: NewDocumentCommand
% args:
%   spec: s o m
% description: Début d'une partie
% example: \partie{Le système binaire}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\partie}{s o m}{%
	\IfBooleanTF{#1}{%
		% Forme étoilée (non numérotée)
		\section*{\prefixepartie\ \ #3}%
	}{%
		% Forme numérotée
		\refstepcounter{compteurpartie}%
		\setcounter{compteursouspartie}{0}%
		\section*{\prefixepartie\ \thecompteurpartie\ :\ \ #3}%
		\ifpartiesDansSommaire
		\addcontentsline{toc}{section}{%
			\IfNoValueTF{#2}{\prefixepartie\ \thecompteurpartie\ :\ #3}{#2}%
		}%
		\fi
	}%
	\setcounter{compteurexercice}{0} 
}

% --- doc
% name: \souspartie
% kind: NewDocumentCommand
% args:
%   spec: s o m
% description: Sous partie
% example: \souspartie{Conversions}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\souspartie}{s o m}{%
	\IfBooleanTF{#1}{%
		\section*{#3}%
	}{%
		\refstepcounter{compteursouspartie}%
		\section*{\thecompteursouspartie\ \hrulefill\ \ #3}%
		\ifpartiesDansSommaire
		\addcontentsline{toc}{subsection}{%
			\IfNoValueTF{#2}{\thecompteursouspartie\ \ #3}{#2}%
		}%
		\fi
	}%
}

