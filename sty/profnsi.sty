\NewDocumentCommand{\pile}{m}{%
  \StrGobbleLeft{#1}{1}[\tempA]
  \StrGobbleRight{\tempA}{1}[\tempB]
  \StrSubstitute{\tempB}{,}{ \\ }[\tempC]
  \tikz[baseline=(pile.base), yshift=0.5ex] {
    \node (pile) [inner sep=0pt] {
      \begin{tabular}{|c|}
        \hline
        \tempC \\
        \hline
      \end{tabular}
    };
    \coordinate (topcenter) at (pile.north);
    \draw[->, very thick] ($(topcenter) + (-0.35cm, 0.7cm)$) -- ($(topcenter) + (-0.35cm, 0.2cm)$)
      node[left] {\tiny Entrée};
    \draw[->, very thick] ($(topcenter) + (0.35cm, 0.2cm)$) -- ($(topcenter) + (0.35cm, 0.7cm)$)
      node[right] {\tiny Sortie};
  }
}

