% ----- QCM -------
% -- Compteur de questions (namespacé)
\newcounter{qcmq}

% -- Liste de choix (namespacée)
\newlist{qcmchoices}{enumerate}{1}
\setlist[qcmchoices]{label=\alph*., leftmargin=*, itemsep=2pt}

% -- Environnement global (facultatif)
\NewDocumentEnvironment{qcm}{ O{} }{\begingroup}{\endgroup}

\NewDocumentEnvironment{qcmquestion}{ O{} }{%
	\refstepcounter{qcmq}%
	\par\medskip
	\noindent\textbf{Question \theqcmq.}%
	\if\relax\detokenize{#1}\relax\else~\emph{[#1]}\fi\quad
	\ignorespaces
}{\par\medskip}


% --- doc
% name: \qcmchoice
% kind: NewDocumentCommand
% args:
%   spec: m
% description: choix de réponse dans un QCM
% example: \qcmchoice{$x^3$}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\qcmchoice}{ m }{\item #1}

% --- doc
% name: \qcmcorrectchoice
% kind: NewDocumentCommand
% args:
%   spec: m
% description: choix de réponse dans un QCM qui est la bonne réponse, mis en rouge en mode prof
% example: \qcmcorrectchoice{$2x$}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\qcmcorrectchoice}{ m }{%
	\ifprofversion
	\item \color{red} \textbf{#1} \color{black}%
	\else
	\item #1%
	\fi
}

% --- doc
% name: \qcmsolution
% kind: NewDocumentCommand
% args:
%   spec: m
% description: explications de réponse de QCM (affiché seulement en version prof)
% example: \qcmsolution{On a $(x^2)'=2x$.}
% meta:
%   file: profnsi.sty
% --- end-doc
\NewDocumentCommand{\qcmsolution}{ m }{%
	\ifprofversion
	\par \color{red}  \smallskip\noindent\textit{Solution : }#1 \color{black} %
	\fi
}

% --- doc
% name: \qcmfreequestion
% kind: NewDocumentCommand
% args:
%   spec: m
% description: Question ouverte de QCM (avec nombre de lignes de réponse et correction)
% example: 	\begin{qcmfreequestion}{Résoudre $x^2-5x+6=0$}[Les racines sont $x=2$ et $x=3$.][5]
	% meta:
	%   file: profnsi.sty
	% --- end-doc
	\NewDocumentEnvironment{qcmfreequestion}{m O{} O{} }{%
		\refstepcounter{qcmq}%
		\par\medskip
		\noindent\textbf{Question \theqcmq.}~#1%
		\par\smallskip
		% Corrigé (uniquement prof)
		\ifprofversion
		\par \color{red} \medskip\noindent\textit{Réponse attendue : }#2 \color{black}%
		\else
		% Zone de réponse élève :
		\lignes{#3}
		\fi
	}{\par\medskip}
	
	% -- (Optionnel) Alias compatibles si *non déjà définis* ailleurs :
	\makeatletter
	\@ifundefined{choices}{%
		\let\choices\qcmchoices
	}{}
	\@ifundefined{question}{%
		\let\question\qcmquestion
	}{}
	\@ifundefined{solution}{%
		\let\solution\qcmsolution
	}{}
	\makeatother
	
	% ----- FIN -----
